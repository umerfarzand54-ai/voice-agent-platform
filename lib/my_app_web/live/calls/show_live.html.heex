<Layouts.app flash={@flash}>
  <div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-8 py-5">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <.link navigate={~p"/calls"} class="text-slate-400 hover:text-slate-600">
            <.icon name="hero-arrow-left" class="w-5 h-5" />
          </.link>
          <div>
            <h1 class="text-2xl font-bold text-slate-900">
              Call with {@call.contact && @call.contact.name || @call.from_number || @call.to_number}
            </h1>
            <p class="text-xs text-slate-400 font-mono mt-0.5">{@call.twilio_call_sid}</p>
          </div>
        </div>

        <%= if @call.status == "completed" and not @call.crm_synced do %>
          <button phx-click="sync_crm" class="inline-flex items-center gap-2 border border-indigo-300 text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
            <.icon name="hero-arrow-path" class="w-4 h-4" />
            Sync to CRM
          </button>
        <% end %>
      </div>
    </div>

    <div class="px-8 py-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
      <%!-- Transcript Panel --%>
      <div class="lg:col-span-2 bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col">
        <div class="px-5 py-4 border-b border-slate-100">
          <h2 class="font-semibold text-slate-800">Conversation Transcript</h2>
        </div>
        <div id="transcript" phx-update="stream" class="flex-1 overflow-y-auto p-5 space-y-3 max-h-[600px]">
          <div class="hidden only:flex items-center justify-center py-10 text-slate-400 text-sm">
            No conversation turns yet
          </div>
          <div :for={{id, turn} <- @streams.turns} id={id}>
            <% {bubble_class, align_class, label} = role_style(turn.role) %>
            <div class={["flex flex-col max-w-[80%]", align_class]}>
              <span class="text-xs text-slate-400 mb-1 px-1">{label}</span>
              <div class={["px-4 py-3 rounded-2xl text-sm leading-relaxed", bubble_class]}>
                {turn.content}
              </div>
              <div class="flex items-center gap-2 mt-1 px-1">
                <%= if turn.language do %>
                  <span class="text-xs text-slate-300">{turn.language}</span>
                <% end %>
                <%= if turn.latency_ms do %>
                  <span class="text-xs text-slate-300">{turn.latency_ms}ms</span>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%!-- Call Info Panel --%>
      <div class="space-y-4">
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
          <h3 class="font-semibold text-slate-800 mb-4">Call Details</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-slate-400 uppercase tracking-wide">Status</dt>
              <dd class="mt-0.5 font-medium text-slate-800 capitalize">{@call.status |> String.replace("_", " ")}</dd>
            </div>
            <div>
              <dt class="text-xs text-slate-400 uppercase tracking-wide">Direction</dt>
              <dd class="mt-0.5 font-medium text-slate-800 capitalize">{@call.direction}</dd>
            </div>
            <div>
              <dt class="text-xs text-slate-400 uppercase tracking-wide">Duration</dt>
              <dd class="mt-0.5 font-medium text-slate-800">{format_duration(@call.duration_seconds)}</dd>
            </div>
            <div>
              <dt class="text-xs text-slate-400 uppercase tracking-wide">Started</dt>
              <dd class="mt-0.5 text-sm text-slate-700">{format_datetime(@call.started_at)}</dd>
            </div>
            <%= if @call.ai_agent do %>
              <div>
                <dt class="text-xs text-slate-400 uppercase tracking-wide">AI Agent</dt>
                <dd class="mt-0.5 font-medium text-slate-800">{@call.ai_agent.name}</dd>
              </div>
            <% end %>
            <%= if @call.detected_language do %>
              <div>
                <dt class="text-xs text-slate-400 uppercase tracking-wide">Detected Language</dt>
                <dd class="mt-0.5 font-medium text-slate-800">{@call.detected_language}</dd>
              </div>
            <% end %>
          </dl>
        </div>

        <%= if @call.status == "completed" do %>
          <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
            <h3 class="font-semibold text-slate-800 mb-4">Outcome</h3>
            <dl class="space-y-3">
              <%= if @call.sentiment do %>
                <div>
                  <dt class="text-xs text-slate-400 uppercase tracking-wide">Sentiment</dt>
                  <% {label, cls} = sentiment_badge(@call.sentiment) %>
                  <dd class="mt-0.5">
                    <span class={["text-xs px-2 py-1 rounded-full font-medium", cls]}>{label}</span>
                  </dd>
                </div>
              <% end %>
              <%= if @call.outcome do %>
                <div>
                  <dt class="text-xs text-slate-400 uppercase tracking-wide">Outcome</dt>
                  <dd class={["mt-0.5 font-medium capitalize", outcome_color(@call.outcome)]}>
                    {@call.outcome |> String.replace("_", " ")}
                  </dd>
                </div>
              <% end %>
              <div>
                <dt class="text-xs text-slate-400 uppercase tracking-wide">CRM Sync</dt>
                <dd class="mt-0.5 text-sm">
                  <%= if @call.crm_synced do %>
                    <span class="text-green-600 font-medium flex items-center gap-1">
                      <.icon name="hero-check-circle" class="w-4 h-4" />
                      Synced
                    </span>
                  <% else %>
                    <span class="text-slate-400">Not synced</span>
                  <% end %>
                </dd>
              </div>
            </dl>
          </div>
        <% end %>

        <%= if @recording_url do %>
          <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
            <h3 class="font-semibold text-slate-800 mb-3">Recording</h3>
            <audio controls class="w-full" id="call-recording" phx-update="ignore">
              <source src={@recording_url} type="audio/mpeg" />
            </audio>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</Layouts.app>
