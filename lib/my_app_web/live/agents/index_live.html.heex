<Layouts.app flash={@flash}>
  <div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-8 py-5">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-slate-900">AI Agents</h1>
          <p class="text-sm text-slate-500 mt-0.5">Configure intelligent voice agents for your calls</p>
        </div>
        <.link navigate={~p"/agents/new"} class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
          <.icon name="hero-plus" class="w-4 h-4" />
          New Agent
        </.link>
      </div>
    </div>

    <div class="px-8 py-6">
      <div id="agents" phx-update="stream" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
        <div class="hidden only:col-span-3 only:flex flex-col items-center justify-center py-20 text-center">
          <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mb-4">
            <.icon name="hero-cpu-chip" class="w-8 h-8 text-indigo-500" />
          </div>
          <h3 class="text-lg font-semibold text-slate-700">No agents yet</h3>
          <p class="text-sm text-slate-400 mt-1 mb-4">Create your first AI voice agent to start automating calls</p>
          <.link navigate={~p"/agents/new"} class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700">
            Create Agent
          </.link>
        </div>

        <div :for={{id, agent} <- @streams.agents} id={id} class="bg-white rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="p-5">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center">
                  <.icon name="hero-cpu-chip" class="w-5 h-5 text-indigo-600" />
                </div>
                <div>
                  <h3 class="font-semibold text-slate-800">{agent.name}</h3>
                  <span class="text-xs text-slate-400">{language_label(agent.language_code)}</span>
                </div>
              </div>
              <button phx-click="toggle_active" phx-value-id={agent.id}
                class={["relative inline-flex h-5 w-9 items-center rounded-full transition-colors", if(agent.active, do: "bg-indigo-600", else: "bg-slate-200")]}>
                <span class={["inline-block h-3.5 w-3.5 transform rounded-full bg-white transition-transform", if(agent.active, do: "translate-x-4", else: "translate-x-1")]}></span>
              </button>
            </div>

            <p class="text-sm text-slate-500 line-clamp-2 mb-4">{agent.description || "No description"}</p>

            <div class="flex items-center gap-2 mb-4">
              <span class="inline-flex items-center gap-1 text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">
                <.icon name="hero-microphone" class="w-3 h-3" />
                {agent.voice_provider}
              </span>
              <span class="inline-flex items-center gap-1 text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-md">
                <.icon name="hero-sparkles" class="w-3 h-3" />
                {agent.llm_model}
              </span>
            </div>

            <div class="flex items-center gap-2 pt-4 border-t border-slate-100">
              <.link navigate={~p"/agents/#{agent.id}/edit"} class="flex-1 text-center text-sm text-slate-600 hover:text-indigo-600 font-medium py-1.5 rounded-lg hover:bg-indigo-50 transition-colors">
                Edit
              </.link>
              <button phx-click="delete" phx-value-id={agent.id}
                data-confirm={"Delete #{agent.name}? This cannot be undone."}
                class="flex-1 text-center text-sm text-red-500 hover:text-red-700 font-medium py-1.5 rounded-lg hover:bg-red-50 transition-colors">
                Delete
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layouts.app>
