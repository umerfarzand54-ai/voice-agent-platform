<Layouts.app flash={@flash}>
  <div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-8 py-5">
      <h1 class="text-2xl font-bold text-slate-900">Settings</h1>
      <p class="text-sm text-slate-500 mt-0.5">Configure your API credentials and integrations</p>
    </div>

    <div class="px-8 py-6 max-w-3xl space-y-6">
      <%!-- Twilio --%>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-slate-800 flex items-center gap-2">
            <.icon name="hero-phone" class="w-5 h-5 text-red-500" />
            Twilio (Telephony)
          </h2>
          <button phx-click="test_twilio" class="text-xs text-indigo-600 hover:text-indigo-800 border border-indigo-200 px-3 py-1 rounded-lg hover:bg-indigo-50 transition-colors">
            Test Connection
          </button>
        </div>
        <%= case test_badge(Map.get(@test_results, :twilio)) do %>
          <% {:ok, msg} -> %>
            <div class="mb-3 text-xs text-emerald-600 bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2 flex items-center gap-1">
              <.icon name="hero-check-circle" class="w-3.5 h-3.5" /> {msg}
            </div>
          <% {:error, reason} -> %>
            <div class="mb-3 text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">{reason}</div>
          <% _ -> %>
        <% end %>
        <div class="space-y-3 text-sm text-slate-600">
          <p><strong>Account SID:</strong> <code class="bg-slate-100 px-2 py-0.5 rounded text-xs">{if String.length(Application.get_env(:my_app, :twilio_account_sid) || "") > 0, do: "Configured ✓", else: "Not set — add TWILIO_ACCOUNT_SID env var"}</code></p>
          <p><strong>Auth Token:</strong> <code class="bg-slate-100 px-2 py-0.5 rounded text-xs">{if String.length(Application.get_env(:my_app, :twilio_auth_token) || "") > 0, do: "Configured ✓", else: "Not set — add TWILIO_AUTH_TOKEN env var"}</code></p>
          <p><strong>Webhook URL (configure in Twilio):</strong> <code class="bg-slate-100 px-2 py-0.5 rounded text-xs">{Application.get_env(:my_app, :base_url) || "http://yourapp.com"}/webhooks/twilio/voice/inbound</code></p>
        </div>
      </div>

      <%!-- ElevenLabs --%>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-slate-800 flex items-center gap-2">
            <.icon name="hero-microphone" class="w-5 h-5 text-purple-500" />
            ElevenLabs (Voice Cloning + TTS)
          </h2>
          <button phx-click="test_elevenlabs" class="text-xs text-indigo-600 hover:text-indigo-800 border border-indigo-200 px-3 py-1 rounded-lg hover:bg-indigo-50 transition-colors">
            Test Connection
          </button>
        </div>
        <%= case test_badge(Map.get(@test_results, :elevenlabs)) do %>
          <% {:ok, msg} -> %>
            <div class="mb-3 text-xs text-emerald-600 bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2 flex items-center gap-1">
              <.icon name="hero-check-circle" class="w-3.5 h-3.5" /> {msg}
            </div>
          <% {:error, reason} -> %>
            <div class="mb-3 text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">{reason}</div>
          <% _ -> %>
        <% end %>
        <p class="text-sm text-slate-600"><strong>API Key:</strong> <code class="bg-slate-100 px-2 py-0.5 rounded text-xs">{if String.length(Application.get_env(:my_app, :elevenlabs_api_key) || "") > 0, do: "Configured ✓", else: "Not set — add ELEVENLABS_API_KEY env var"}</code></p>
      </div>

      <%!-- Sarvam AI --%>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-slate-800 flex items-center gap-2">
            <.icon name="hero-globe-alt" class="w-5 h-5 text-orange-500" />
            Sarvam AI (Indian Languages)
          </h2>
          <button phx-click="test_sarvam" class="text-xs text-indigo-600 hover:text-indigo-800 border border-indigo-200 px-3 py-1 rounded-lg hover:bg-indigo-50 transition-colors">
            Test Connection
          </button>
        </div>
        <%= case test_badge(Map.get(@test_results, :sarvam)) do %>
          <% {:ok, msg} -> %>
            <div class="mb-3 text-xs text-emerald-600 bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2 flex items-center gap-1">
              <.icon name="hero-check-circle" class="w-3.5 h-3.5" /> {msg}
            </div>
          <% {:error, reason} -> %>
            <div class="mb-3 text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">{reason}</div>
          <% _ -> %>
        <% end %>
        <div class="text-sm text-slate-600 space-y-1">
          <p><strong>API Key:</strong> <code class="bg-slate-100 px-2 py-0.5 rounded text-xs">{if String.length(Application.get_env(:my_app, :sarvam_api_key) || "") > 0, do: "Configured ✓", else: "Not set — add SARVAM_API_KEY env var"}</code></p>
          <p class="text-xs text-slate-400">Supports: Hindi, Tamil, Telugu, Kannada, Malayalam, Bengali, Gujarati, Marathi</p>
        </div>
      </div>

      <%!-- Claude --%>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-slate-800 flex items-center gap-2">
            <.icon name="hero-sparkles" class="w-5 h-5 text-amber-500" />
            Claude AI (Conversation Engine)
          </h2>
          <button phx-click="test_claude" class="text-xs text-indigo-600 hover:text-indigo-800 border border-indigo-200 px-3 py-1 rounded-lg hover:bg-indigo-50 transition-colors">
            Test Connection
          </button>
        </div>
        <%= case test_badge(Map.get(@test_results, :claude)) do %>
          <% {:ok, msg} -> %>
            <div class="mb-3 text-xs text-emerald-600 bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2 flex items-center gap-1">
              <.icon name="hero-check-circle" class="w-3.5 h-3.5" /> {msg}
            </div>
          <% {:error, reason} -> %>
            <div class="mb-3 text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">{reason}</div>
          <% _ -> %>
        <% end %>
        <p class="text-sm text-slate-600"><strong>API Key:</strong> <code class="bg-slate-100 px-2 py-0.5 rounded text-xs">{if String.length(Application.get_env(:my_app, :claude_api_key) || "") > 0, do: "Configured ✓", else: "Not set — add CLAUDE_API_KEY env var"}</code></p>
      </div>

      <%!-- CRM --%>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <h2 class="font-semibold text-slate-800 mb-4 flex items-center gap-2">
          <.icon name="hero-building-office" class="w-5 h-5 text-blue-500" />
          CRM Integrations
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
          <div class="border border-slate-100 rounded-xl p-4">
            <h3 class="font-medium text-slate-700 mb-2">Zoho CRM</h3>
            <p class="text-xs text-slate-500 mb-2">Set env vars: ZOHO_REFRESH_TOKEN, ZOHO_CLIENT_ID, ZOHO_CLIENT_SECRET</p>
            <code class={["text-xs px-2 py-0.5 rounded-full", if(Application.get_env(:my_app, :zoho_refresh_token), do: "bg-emerald-100 text-emerald-700", else: "bg-slate-100 text-slate-500")]}>
              {if Application.get_env(:my_app, :zoho_refresh_token), do: "✓ Connected", else: "Not configured"}
            </code>
          </div>
          <div class="border border-slate-100 rounded-xl p-4">
            <h3 class="font-medium text-slate-700 mb-2">Bitrix24</h3>
            <p class="text-xs text-slate-500 mb-2">Set env var: BITRIX24_WEBHOOK_URL</p>
            <code class={["text-xs px-2 py-0.5 rounded-full", if(Application.get_env(:my_app, :bitrix24_webhook_url), do: "bg-emerald-100 text-emerald-700", else: "bg-slate-100 text-slate-500")]}>
              {if Application.get_env(:my_app, :bitrix24_webhook_url), do: "✓ Connected", else: "Not configured"}
            </code>
          </div>
        </div>
      </div>

      <%!-- Webhook URL Info --%>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
        <h3 class="font-semibold text-amber-900 mb-2 flex items-center gap-2">
          <.icon name="hero-information-circle" class="w-5 h-5" />
          Twilio Webhook Configuration
        </h3>
        <p class="text-sm text-amber-800 mb-2">Configure these URLs in your Twilio phone number settings:</p>
        <ul class="space-y-1 text-xs font-mono text-amber-700">
          <li>• Voice webhook (POST): <strong>/webhooks/twilio/voice/inbound</strong></li>
          <li>• Status callback (POST): <strong>/webhooks/twilio/voice/status</strong></li>
        </ul>
        <p class="text-xs text-amber-600 mt-3">For local development, use ngrok or similar to expose your local port.</p>
      </div>
    </div>
  </div>
</Layouts.app>
