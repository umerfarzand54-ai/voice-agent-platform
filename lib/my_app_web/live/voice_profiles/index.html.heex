<Layouts.app flash={@flash}>
  <div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-8 py-5">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Voice Profiles</h1>
        <p class="text-sm text-slate-500 mt-0.5">Clone custom voices using ElevenLabs AI voice cloning</p>
      </div>
    </div>

    <div class="px-8 py-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
      <%!-- Clone Voice Form --%>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <h2 class="font-semibold text-slate-800 mb-4 flex items-center gap-2">
          <.icon name="hero-microphone" class="w-5 h-5 text-purple-500" />
          Clone a Voice
        </h2>

        <.form for={@form} id="clone-form" phx-change="validate" phx-submit="clone_voice" class="space-y-4">
          <.input field={@form[:name]} type="text" label="Voice Name" placeholder="e.g. Priya - Sales" />
          <.input field={@form[:language]} type="select" label="Primary Language"
            options={[{"English", "en-IN"}, {"Hindi", "hi-IN"}, {"Tamil", "ta-IN"}, {"Telugu", "te-IN"}, {"Kannada", "kn-IN"}, {"Malayalam", "ml-IN"}]} />
          <.input field={@form[:ai_agent_id]} type="select" label="Assign to Agent (optional)"
            options={[{"— None —", ""}] ++ @agents} />

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Audio Samples (2-5 clips, 1-3 min each)</label>
            <div id="upload-area" phx-drop-target={@uploads.audio_samples.ref}
              class="border-2 border-dashed border-slate-200 rounded-xl p-6 text-center hover:border-indigo-300 transition-colors">
              <.icon name="hero-cloud-arrow-up" class="w-8 h-8 mx-auto text-slate-300 mb-2" />
              <p class="text-sm text-slate-500">Drag audio files here or</p>
              <label for={@uploads.audio_samples.ref} class="cursor-pointer text-sm text-indigo-600 hover:text-indigo-800 font-medium">browse files</label>
              <.live_file_input upload={@uploads.audio_samples} class="sr-only" />
              <p class="text-xs text-slate-400 mt-1">MP3, WAV, M4A up to 50MB each</p>
            </div>

            <div class="mt-2 space-y-1.5">
              <div :for={entry <- @uploads.audio_samples.entries} class="flex items-center gap-2 text-sm">
                <.icon name="hero-musical-note" class="w-4 h-4 text-indigo-400" />
                <span class="flex-1 text-slate-700 truncate">{entry.client_name}</span>
                <span class="text-xs text-slate-400">{Float.round(entry.progress / 1.0, 0)}%</span>
                <button type="button" phx-click="cancel-upload" phx-value-ref={entry.ref} class="text-red-400 hover:text-red-600">
                  <.icon name="hero-x-mark" class="w-4 h-4" />
                </button>
              </div>
            </div>
          </div>

          <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white px-4 py-2.5 rounded-lg font-medium transition-colors flex items-center justify-center gap-2">
            <.icon name="hero-sparkles" class="w-4 h-4" />
            Clone Voice with ElevenLabs
          </button>
        </.form>

        <div class="mt-4 p-3 bg-amber-50 rounded-lg border border-amber-100">
          <p class="text-xs text-amber-700">
            <strong>Tips for best results:</strong> Use clear recordings with minimal background noise. 2-3 minutes of natural speech gives the best voice quality.
          </p>
        </div>
      </div>

      <%!-- Profiles List --%>
      <div class="lg:col-span-2">
        <div id="profiles" phx-update="stream" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="hidden only:col-span-2 only:flex flex-col items-center justify-center py-16 bg-white rounded-xl border border-slate-200 text-center">
            <.icon name="hero-microphone" class="w-10 h-10 text-slate-300 mb-3" />
            <p class="text-slate-400">No voice profiles yet</p>
          </div>

          <div :for={{id, profile} <- @streams.profiles} id={id} class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="font-semibold text-slate-800">{profile.name}</h3>
                <div class="text-xs text-slate-400 mt-0.5">
                  {profile.ai_agent && profile.ai_agent.name || "Not assigned"}
                </div>
              </div>
              <% {label, cls} = status_badge(profile.status) %>
              <span class={["text-xs px-2 py-0.5 rounded-full font-medium", cls]}>{label}</span>
            </div>

            <dl class="space-y-1.5 text-xs text-slate-500 mb-4">
              <div class="flex justify-between">
                <dt>Provider</dt>
                <dd class="font-medium text-slate-700 capitalize">{profile.provider}</dd>
              </div>
              <div class="flex justify-between">
                <dt>Language</dt>
                <dd class="font-medium text-slate-700">{profile.language}</dd>
              </div>
              <div class="flex justify-between">
                <dt>Voice ID</dt>
                <dd class="font-mono text-xs text-slate-400 truncate max-w-[120px]">{profile.external_voice_id || "—"}</dd>
              </div>
            </dl>

            <div class="flex items-center gap-2 pt-3 border-t border-slate-100">
              <%= if profile.ai_agent_id && profile.status == "ready" && not profile.active do %>
                <button phx-click="activate" phx-value-id={profile.id} phx-value-agent_id={profile.ai_agent_id}
                  class="flex-1 text-center text-xs bg-indigo-600 hover:bg-indigo-700 text-white py-1.5 rounded-lg font-medium transition-colors">
                  Activate for Agent
                </button>
              <% end %>
              <%= if profile.active do %>
                <span class="flex-1 text-center text-xs text-emerald-600 font-medium flex items-center justify-center gap-1">
                  <.icon name="hero-check-circle" class="w-3.5 h-3.5" />
                  Active
                </span>
              <% end %>
              <button phx-click="delete" phx-value-id={profile.id}
                data-confirm={"Delete voice profile #{profile.name}?"}
                class="text-red-400 hover:text-red-600 p-1.5 rounded-lg hover:bg-red-50">
                <.icon name="hero-trash" class="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layouts.app>
