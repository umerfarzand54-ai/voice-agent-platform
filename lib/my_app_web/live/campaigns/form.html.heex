<Layouts.app flash={@flash}>
  <div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-8 py-5">
      <div class="flex items-center gap-3">
        <.link navigate={~p"/campaigns"} class="text-slate-400 hover:text-slate-600">
          <.icon name="hero-arrow-left" class="w-5 h-5" />
        </.link>
        <div>
          <h1 class="text-2xl font-bold text-slate-900">{@page_title}</h1>
          <p class="text-sm text-slate-500 mt-0.5">Set up your outbound calling campaign</p>
        </div>
      </div>
    </div>

    <div class="px-8 py-6 max-w-3xl">
      <.form for={@form} id="campaign-form" phx-change="validate" phx-submit="save" class="space-y-6">
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
          <h2 class="text-base font-semibold text-slate-800 mb-4">Basic Info</h2>
          <div class="space-y-4">
            <.input field={@form[:name]} type="text" label="Campaign Name" placeholder="Q2 Lead Follow-up" />
            <.input field={@form[:description]} type="textarea" label="Description" rows="2"
              placeholder="Brief description of campaign goals..." />
            <.input field={@form[:ai_agent_id]} type="select" label="AI Agent"
              options={[{"— Select an agent —", ""}] ++ @agents} />
          </div>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
          <h2 class="text-base font-semibold text-slate-800 mb-4">Call Settings</h2>
          <div class="grid grid-cols-2 gap-4">
            <.input field={@form[:from_number]} type="text" label="From Number (E.164)"
              placeholder="+919876543210" />
            <.input field={@form[:concurrent_calls]} type="number" label="Concurrent Calls"
              min="1" max="50" placeholder="5" />
            <.input field={@form[:max_attempts]} type="number" label="Max Attempts per Contact"
              min="1" max="10" placeholder="3" />
            <.input field={@form[:retry_delay_minutes]} type="number" label="Retry Delay (minutes)"
              min="15" placeholder="60" />
          </div>
          <div class="mt-4">
            <.input field={@form[:goal_prompt]} type="textarea" label="Campaign Goal" rows="2"
              placeholder="Book a demo appointment for our product..." />
          </div>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
          <h2 class="text-base font-semibold text-slate-800 mb-4">Schedule</h2>
          <div class="grid grid-cols-2 gap-4">
            <.input field={@form[:schedule_start]} type="datetime-local" label="Start Date/Time" />
            <.input field={@form[:schedule_end]} type="datetime-local" label="End Date/Time" />
            <.input field={@form[:calling_window_start]} type="time" label="Calling Window Start" />
            <.input field={@form[:calling_window_end]} type="time" label="Calling Window End" />
          </div>
        </div>

        <div class="flex items-center gap-3">
          <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-lg font-medium transition-colors">
            {if @live_action == :new, do: "Create Campaign", else: "Save Changes"}
          </button>
          <.link navigate={~p"/campaigns"} class="text-slate-500 hover:text-slate-700 px-4 py-2.5 font-medium">
            Cancel
          </.link>
        </div>
      </.form>
    </div>
  </div>
</Layouts.app>
