<Layouts.app flash={@flash}>
  <div class="min-h-screen bg-slate-50">
    <div class="bg-white border-b border-slate-200 px-8 py-5">
      <div class="flex items-center gap-3">
        <.link navigate={~p"/contacts"} class="text-slate-400 hover:text-slate-600">
          <.icon name="hero-arrow-left" class="w-5 h-5" />
        </.link>
        <h1 class="text-2xl font-bold text-slate-900">{@page_title}</h1>
      </div>
    </div>

    <div class="px-8 py-6 max-w-xl">
      <.form for={@form} id="contact-form" phx-change="validate" phx-submit="save" class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 space-y-4">
        <.input field={@form[:name]} type="text" label="Full Name" placeholder="Rahul Sharma" />
        <.input field={@form[:phone_number]} type="text" label="Phone Number (E.164)" placeholder="+919876543210" />
        <.input field={@form[:email]} type="email" label="Email" placeholder="rahul@example.com" />
        <.input field={@form[:language_pref]} type="select" label="Preferred Language" options={@language_options} />
        <.input field={@form[:timezone]} type="text" label="Timezone" placeholder="Asia/Kolkata" />

        <div class="flex gap-3 pt-2">
          <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg font-medium text-sm transition-colors">
            {if @live_action == :new, do: "Add Contact", else: "Save"}
          </button>
          <.link navigate={~p"/contacts"} class="text-slate-500 hover:text-slate-700 px-4 py-2 font-medium text-sm">
            Cancel
          </.link>
        </div>
      </.form>
    </div>
  </div>
</Layouts.app>
